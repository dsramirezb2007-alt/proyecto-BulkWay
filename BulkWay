@startuml
skinparam classAttributeIconSize 0
skinparam Style strictuml

package "Capa de Datos - Entidades" {

    class Cliente {
        - idCliente: Long
        - documento: String
        - nombre: String
        - apellido: String
        - direccion: String
        - telefono: String
        - correo: String
        + registrarCliente(obj: Cliente): boolean
        + actualizarDatos(obj: Cliente): boolean
        + buscarCliente(documento: String): Cliente
    }

    class Pedido {
        - idPedido: Long
        - idCliente: Long
        - fecha: Date
        - hora: Time
        - total: double
        - estado: String
        + crearPedido(lista: List<Detalle>): boolean
        + cancelarPedido(id: Long): boolean
        + calcularTotal(): double
        + generarRecibo(): String
    }

    class DetallePedido {
        - idDetalle: Long
        - idPedido: Long
        - idProducto: Long
        - cantidad: int
        - precioUnitario: double
        - subtotal: double
        - iva: double
        + calcularSubtotal(): void
        + EditarDetallePedido(): void
    }

    class Producto {
        - idProducto: Long
        - codigo: String
        - nombre: String
        - precio: double
        - stockActual: int
        - descripcion: String
        + validarStock(cantidad: int): boolean
        + actualizarStock(cantidad: int): void
        + consultarPrecio(): double
    }

    class Envio {
        - idEnvio: Long
        - idEmpleado: Long
        - codigoSeguimiento: String
        - ruta: String
        - fechaSalida: Date
        + asignarRepartidor(idEmp: Long): void
        + actualizarEstado(estado: String): void
    }

    class Empleado {
        - idEmpleado: Long
        - nombre: String
        - cargo: String
        - telefono: String
        - email: String
        - password: String
        + autenticar(user: String, pass: String): boolean
        + generarReporteVentas(): void
        +ActualizarEmpleado(estado: String): void
    }
}

' Relaciones Técnicas
Cliente "1" -- "0..*" Pedido : solicita >
Pedido "1" *-- "1..*" DetallePedido : posee >
DetallePedido "*" -- "1" Producto : incluye >
Pedido "1" -- "0..1" Envio : se despacha >
Envio "*" -- "1" Empleado : entrega <

@enduml
